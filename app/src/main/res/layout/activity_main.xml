<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/app_name"
            app:titleTextColor="@color/white"
            app:subtitleTextColor="#E0E0E0" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Due Dashboard -->
    <androidx.cardview.widget.CardView
        android:id="@+id/dashboardCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Outstanding Balance"
                android:textColor="#757575"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/totalNetDue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹0.00"
                android:textColor="@color/give_red"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/shopNameSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#424242"
                android:textSize="14sp"
                tools:text="Shop: Gramakhata" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- List of People -->
    <ListView
        android:id="@+id/customerList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp"
        android:paddingHorizontal="4dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toBottomOf="@id/dashboardCard" />

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTake"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/take_green"
                android:text="GOT MONEY\n(ಹಣ ಬಂತು)"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnGive"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/give_red"
                android:text="GAVE CREDIT\n(ಸಾಲ ಕೊಟ್ಟೆ)"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnReport"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Share Collection Report"
            android:textColor="@color/primary"
            app:strokeColor="@color/primary"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>